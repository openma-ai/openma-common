{
  "name": "@openma/common",
  "version": "0.5.0",
  "private": true,
  "description": "Shared OpenMA brand assets, design tokens, and session event adapters.",
  "repository": {
    "type": "git",
    "url": "https://github.com/openma-ai/openma-common.git"
  },
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "./brand": {
      "types": "./dist/brand/index.d.ts",
      "import": "./dist/brand/index.js"
    },
    "./brand/tokens.css": "./dist/brand/tokens.css",
    "./brand/openma-logo-mark.svg": "./dist/brand/openma-logo-mark.svg",
    "./session-events/managed": {
      "types": "./dist/session-events/managed.d.ts",
      "import": "./dist/session-events/managed.js"
    },
    "./session-events/acp": {
      "types": "./dist/session-events/acp.d.ts",
      "import": "./dist/session-events/acp.js"
    },
    "./session-kernel": {
      "types": "./dist/session-kernel/index.d.ts",
      "import": "./dist/session-kernel/index.js"
    },
    "./acp-runtime": {
      "types": "./dist/acp-runtime/index.d.ts",
      "import": "./dist/acp-runtime/index.js"
    },
    "./acp-runtime/node-spawner": {
      "types": "./dist/acp-runtime/spawners/node.d.ts",
      "import": "./dist/acp-runtime/spawners/node.js"
    },
    "./acp-runtime/errors": {
      "types": "./dist/acp-runtime/errors.d.ts",
      "import": "./dist/acp-runtime/errors.js"
    },
    "./session-ui": {
      "types": "./dist/session-ui/index.d.ts",
      "import": "./dist/session-ui/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-static-assets.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:consumers": "node scripts/dev-consumers.mjs",
    "link:consumers": "node scripts/consumers.mjs link",
    "unlink:consumers": "node scripts/consumers.mjs unlink",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm test && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/node": "^25.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "packageManager": "pnpm@11.0.8"
}
